{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chikennokura",
  "main": "worker.js",
  "compatibility_date": "2026-05-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],

  // -------------------------------------------------------
  // Supabase 接続情報は wrangler secret として管理しています
  //   npx wrangler secret put SUPABASE_URL
  //   npx wrangler secret put SUPABASE_ANON_KEY
  // ローカル開発時は .dev.vars に記述してください
  // -------------------------------------------------------

  // -------------------------------------------------------
  // ローカル開発: 状態ファイルをプロジェクト外に置く
  // 日本語パス内の .wrangler/state が引き起こす無限リロードを防ぐ
  // -------------------------------------------------------
  "dev": {
    "persist_to": "C:\\wrangler-state"
  }
}
